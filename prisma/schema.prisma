generator client {
  provider = "prisma-client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String
  plan      String   @default("free")
  status    String   @default("active")
  stripeId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UsageTracking {
  id        String   @id @default(cuid())
  userId    String
  tool      String
  count     Int      @default(0)\n  month     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, tool, month])
}
